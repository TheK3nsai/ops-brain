# Database
DATABASE_URL=postgresql://ops_brain:ops_brain@localhost:5432/ops_brain

# Transport: stdio or http
OPS_BRAIN_TRANSPORT=stdio

# HTTP settings (Phase 2)
OPS_BRAIN_LISTEN=0.0.0.0:3000
OPS_BRAIN_AUTH_TOKEN=

# Logging
RUST_LOG=ops_brain=info

# Auto-migrate on startup
OPS_BRAIN_MIGRATE=true
