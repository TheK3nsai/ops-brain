# Database (required)
DATABASE_URL=postgresql://ops_brain:ops_brain@localhost:5432/ops_brain

# Transport: stdio (local Claude Code MCP) or http (Docker / remote access)
# Docker Compose users: must be 'http' — stdio crashes in containers
OPS_BRAIN_TRANSPORT=http

# HTTP settings (only used when transport=http)
OPS_BRAIN_LISTEN=0.0.0.0:3000
OPS_BRAIN_AUTH_TOKEN=

# Auto-migrate on startup
OPS_BRAIN_MIGRATE=true

# Logging
RUST_LOG=ops_brain=info

# Embeddings (optional — requires ollama or OpenAI-compatible API)
OPS_BRAIN_EMBEDDINGS_ENABLED=false
OPS_BRAIN_EMBEDDING_URL=http://localhost:11434/v1/embeddings
OPS_BRAIN_EMBEDDING_MODEL=nomic-embed-text
# OPS_BRAIN_EMBEDDING_API_KEY=

# Uptime Kuma monitoring (optional)
# UPTIME_KUMA_URL=http://uptime-kuma:3001
# UPTIME_KUMA_USERNAME=
# UPTIME_KUMA_PASSWORD=

# Watchdog (optional — requires UPTIME_KUMA_URL)
OPS_BRAIN_WATCHDOG_ENABLED=false
OPS_BRAIN_WATCHDOG_INTERVAL=60
OPS_BRAIN_WATCHDOG_CONFIRM_POLLS=3
OPS_BRAIN_WATCHDOG_COOLDOWN_SECS=1800
OPS_BRAIN_WATCHDOG_FLAP_THRESHOLD=5

# Zammad ticketing (optional)
# ZAMMAD_URL=http://zammad-railsserver:3000
# ZAMMAD_API_TOKEN=
# ZAMMAD_DEFAULT_OWNER_ID=
